{
  "expo": {
    "name": "DYNO Esport Manager",
    "slug": "eva-esport-arena",
    "owner": "dynoxaphexs-team",
    "scheme": "evaesportarena",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/logo-dyno.png",
    "splash": {
      "image": "./assets/images/logo-dyno.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-calendar",
        {
          "calendarPermission": "Autoriser DYNO Esport Manager à ajouter les matchs à votre calendrier."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-dyno.png",
          "color": "#D4AF37",
          "defaultChannel": "matches"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fc6db2ba-e1c7-4ceb-b720-f97787f7425c"
    },
    "android": {
      "package": "com.dynoaphex.evaesportarena",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-dyno.png",
        "backgroundColor": "#050505"
      },
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.dynoaphex.evaesportarena"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo-dyno.png"
    },
    "extra": {
      "eas": {
        "projectId": "fc6db2ba-e1c7-4ceb-b720-f97787f7425c"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Eva-Esport-Arena"
    }
  }
}