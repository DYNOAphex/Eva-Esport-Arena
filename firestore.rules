rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'thibaut.llorens@hotmail.com';
    }

    function availabilityOnlyUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responses']);
    }

    function validRosterPlayer() {
      return request.resource.data.keys().hasOnly([
          'nickname',
          'createdAt',
          'accountUid',
          'accountEmail'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 24
        && request.resource.data.createdAt is string
        && request.resource.data.accountUid is string
        && request.resource.data.accountEmail is string;
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || availabilityOnlyUpdate();
    }

    match /roster/{playerId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validRosterPlayer();
      allow delete: if isAdmin();
    }

    match /appAccess/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/webPushSubscriptions/{subscriptionId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
