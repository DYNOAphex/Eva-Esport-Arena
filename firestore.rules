rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'thibaut.llorens@hotmail.com';
    }

    function availabilityOnlyUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responses']);
    }

    function validRosterPlayer() {
      return request.resource.data.keys().hasOnly([
          'nickname',
          'createdAt',
          'accountUid',
          'accountEmail'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 24
        && request.resource.data.createdAt is string
        && request.resource.data.accountUid is string
        && request.resource.data.accountEmail is string;
    }

    function validSupportReport() {
      return request.resource.data.keys().hasOnly([
          'message',
          'userId',
          'email',
          'role',
          'platform',
          'version',
          'notificationsEnabled',
          'reminder24h',
          'reminder1h',
          'webPushDiagnostic',
          'createdAt',
          'status'
        ])
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 1200
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role is string
        && request.resource.data.platform is string
        && request.resource.data.version is string
        && request.resource.data.notificationsEnabled is bool
        && request.resource.data.reminder24h is bool
        && request.resource.data.reminder1h is bool
        && request.resource.data.webPushDiagnostic is string
        && request.resource.data.createdAt is string
        && request.resource.data.status == 'Nouveau';
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || availabilityOnlyUpdate();
    }

    match /roster/{playerId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validRosterPlayer();
      allow delete: if isAdmin();
    }

    match /appAccess/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /supportReports/{reportId} {
      allow create: if signedIn() && validSupportReport();
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/webPushSubscriptions/{subscriptionId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
